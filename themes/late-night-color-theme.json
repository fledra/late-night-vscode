      }
    },
    {
      "scope": "support",
      "settings": {
        "foreground": "#718ca1"
      }
    },
    {
      "scope": "support.type.primitive",
      "settings": {
        "foreground": "#33ced8"
      }
    },
    {
      "scope": "support.class.component",
      "settings": {
        "foreground": "#33ced8"
      }
    },
    {
