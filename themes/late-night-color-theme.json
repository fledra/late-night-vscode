  "tokenColors": [
    {
      "scope": [
        "comment",
        "string.comment",
        "string.quoted.docstring",
        "string.quoted.docstring punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#41505e"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#5ec4ff"
      }
    },
    {
      "scope": "constant",
      "settings": {
        "foreground": "#e27e8d"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#d95468"
      }
    },
    {
      "scope": "meta",
      "settings": {
        "foreground": "#718ca1"
      }
    },
    {
      "scope": [
        "string",
        "string.template",
        "meta.template.expression",
        "punctuation.definition.string",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#68a1f0"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#718ca1"
      }
    },
    {
      "scope": "punctuation.accessor",
      "settings": {
        "foreground": "#b7c5d3"
      }
    },
    {
      "scope": "punctuation.separator.annotation.result",
      "settings": {
        "foreground": "#5ec4ff"
      }
    },
    {
      "scope": ["variable", "support.variable", "meta.object.member"],
      "settings": {
        "foreground": "#718ca1"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#ebbf83"
      }
    },
    {
      "scope": ["variable.other.constant", "variable.object.property"],
      "settings": {
        "foreground": "#8bd49c"
      }
    },
    {
      "scope": "variable.other.readwrite",
      "settings": {
        "foreground": "#b7c5d3"
      }
    },
    {
      "scope": "variable.other.readwrite.alias",
      "settings": {
        "foreground": "#718ca1"
      }
    },
    {
      "scope": "variable.language.super",
      "settings": {
        "foreground": "#b62d65"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.special.self",
        "variable.parameter.function.language.special.self"
      ],
      "settings": {
        "foreground": "#d98e48"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#008b94"
      }
    },
    {
      "scope": "storage.modifier",
      "settings": {
        "foreground": "#5ec4ff"
      }
    },
    {
      "scope": "entity",
      "settings": {
        "foreground": "#70e1e8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.function-call support.type",
        "support.function.builtin",
        "support.function.magic"
      ],
      "settings": {
        "foreground": "#70e1e8"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "meta.decorator variable.other.readwrite",
        "meta.function.decorator",
        "meta.function.decorator support.type"
      ],
      "settings": {
        "foreground": "#70e1e8"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.alias",
        "entity.name.type.instance",
        "entity.name.type.interface",
