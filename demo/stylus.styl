// 1. Variables and Hash Maps
primary-blue = #1a3a4a
accent-red = #5a1d1d
spacing = 10px

colors = {
  success: #2ecc71,
  error: accent-red,
  warning: #f1c40f
}

// 2. Mixins (without parentheses or braces)
flex-center(direction = row)
  display flex
  flex-direction direction
  justify-content center
  align-items center

// 3. Functions with Math
calculate-rem(size)
  return (size / 16)rem

// 4. Nesting and Transparent Mixins
.main-wrapper
  flex-center column
  padding calculate-rem(20)
  background-color primary-blue

  // Parent reference and BEM
  &__header
    width 100%
    border-bottom 1px solid rgba(white, 0.2)

    h1
      font-size 2.5rem
      color white

  // 5. Conditionals and Iteration
  for name, value in colors
    .alert-{name}
      border-left 5px solid value
      if name == 'error'
        background rgba(value, 0.1)
      else
        background transparent

// 6. Complex Selectors and Pseudo-elements
#main-layout
  .container
    > article
      &[data-active='true']
        &:hover
          background lighten(primary-blue, 10%)

        &::after
          content 'Active'
          color accent-red

// 7. Property Lookup (Unique to Stylus)
.dynamic-box
  width 500px
  height (@width / 2) // Accesses the value of 'width'
  margin-top -(@height)

// 8. Built-in Functions and Interpolation
[data-icon=\"{icon-name}\"]
  background-image url('images/' + icon-name + '.png')
  filter grayscale(1)
